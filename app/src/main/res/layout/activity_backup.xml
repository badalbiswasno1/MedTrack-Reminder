<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_header"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ব্যাকআপ"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="সব ওষুধ ও লগের তথ্য CSV ফাইলে এক্সপোর্ট করুন"
            android:textColor="#D9FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:layout_margin="16dp"
        android:padding="18dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="এখনো কোনো ব্যাকআপ তৈরি হয়নি"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/exportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_day_upcoming"
            android:gravity="center"
            android:padding="14dp"
            android:text="CSV এক্সপোর্ট করুন"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/shareButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_card"
            android:gravity="center"
            android:padding="14dp"
            android:text="ফাইল শেয়ার করুন"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
