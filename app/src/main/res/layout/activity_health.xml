<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="স্বাস্থ্য ড্যাশবোর্ড"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Quick Counters: Smoking + Water -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="16dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚬 ধূমপান"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/smokingCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="@color/danger"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="আজকে"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/smokingAddButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_circle_accent"
                    android:gravity="center"
                    android:text="+1"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 পানি"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/waterCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="@color/primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="গ্লাস আজকে"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/waterAddButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_circle_primary"
                    android:gravity="center"
                    android:text="+1"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Heart Rate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❤️ হৃদস্পন্দন"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/latestHeartRateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="এখনো কোনো তথ্য নেই"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/heartRateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="BPM (প্রতি মিনিটে স্পন্দন)"
                android:inputType="number"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp" />

            <TextView
                android:id="@+id/saveHeartRateButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="12dp"
                android:text="সেভ করুন"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Blood Pressure -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🩸 রক্তচাপ (BP)"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/latestBpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="এখনো কোনো তথ্য নেই"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <EditText
                    android:id="@+id/bpSystolicInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="সিস্টোলিক"
                    android:inputType="number"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp" />

                <EditText
                    android:id="@+id/bpDiastolicInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="ডায়াস্টলিক"
                    android:inputType="number"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/saveBpButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="12dp"
                android:text="সেভ করুন"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Blood Sugar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🩺 রক্তে সুগার"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/latestSugarText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="এখনো কোনো তথ্য নেই"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/sugarInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="mg/dL"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp" />

            <TextView
                android:id="@+id/saveSugarButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="12dp"
                android:text="সেভ করুন"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Weight -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚖ ওজন"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/latestWeightText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="এখনো কোনো তথ্য নেই"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/weightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="কেজি"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp" />

            <TextView
                android:id="@+id/saveWeightButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="12dp"
                android:text="সেভ করুন"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Lipid Profile -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧪 লিপিড প্রোফাইল"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/latestLipidText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="এখনো কোনো তথ্য নেই"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/lipidTotalInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="মোট কোলেস্টেরল (mg/dL)"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp" />

            <EditText
                android:id="@+id/lipidLdlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="LDL (mg/dL)"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp" />

            <TextView
                android:id="@+id/saveLipidButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="12dp"
                android:text="সেভ করুন"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
