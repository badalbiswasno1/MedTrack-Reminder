<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="সাহায্য কেন্দ্র"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- FAQ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="সাধারণ জিজ্ঞাসা"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="রিমাইন্ডার কাজ করছে না কেন?"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ফোনের Battery Optimization থেকে MedTrack কে বাদ দিন (Settings → Apps → MedTrack → Battery → Unrestricted), এবং নোটিফিকেশন পারমিশন চালু আছে কিনা দেখুন।"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="নোটিফিকেশন কেন আসছে না?"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Settings → Apps → MedTrack → Notifications এ গিয়ে সব notification channel চালু আছে কিনা যাচাই করুন। প্রয়োজনের সময় Do Not Disturb মোড বন্ধ রাখুন।"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ব্যাকগ্রাউন্ডে অ্যাপ বন্ধ হয়ে যায় কেন?"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="কিছু ফোনে (Xiaomi, Oppo, Vivo) নিজস্ব battery saver থাকে যা অ্যাপকে জোর করে বন্ধ করে দেয়। সেটিংসে গিয়ে MedTrack কে Autostart/Protected App হিসেবে চিহ্নিত করুন।"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ওষুধ ম্যানেজমেন্ট কীভাবে করবো?"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="হোম স্ক্রিনের + বাটনে ওষুধ যোগ করুন, স্টক ফুরিয়ে গেলে Low Stock পেজে দেখা যাবে, প্রতিদিনের হিসাব Statistics পেজে পাবেন।"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- About -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="অ্যাপ সম্পর্কে"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MedTrack — Version 1.0"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer: Badal Biswas"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/contactButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="12dp"
                android:text="✉️ ডেভেলপারকে ইমেইল করুন"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/shareButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:padding="12dp"
                android:text="📤 অ্যাপটি শেয়ার করুন"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Privacy + Terms -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:layout_marginTop="0dp"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="গোপনীয়তা ও শর্তাবলী"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="গোপনীয়তা নীতি\n\nMedTrack আপনার কোনো ব্যক্তিগত বা স্বাস্থ্য সংক্রান্ত তথ্য কোনো বাইরের সার্ভারে পাঠায় না বা কোনো তৃতীয় পক্ষের সাথে শেয়ার করে না। ওষুধের নাম, ডোজ, স্বাস্থ্য রিডিং (BP/সুগার/ওজন ইত্যাদি), এবং ব্যবহারের ইতিহাস — সবকিছু শুধুমাত্র আপনার ফোনের স্থানীয় ডাটাবেসে সংরক্ষিত থাকে। প্রেসক্রিপশন স্ক্যান (OCR) এবং ভাষা অনুবাদ সম্পূর্ণ অফলাইনে, আপনার ডিভাইসেই সম্পন্ন হয়। আপনি যদি নিজে ব্যাকআপ ফাইল (CSV) শেয়ার করেন, শুধু তখনই সেই তথ্য আপনার ফোনের বাইরে যায় — সম্পূর্ণ আপনার নিয়ন্ত্রণে।\n\nশর্তাবলী\n\nMedTrack একটি ব্যক্তিগত ওষুধ ব্যবস্থাপনার সহায়ক টুল, এটি কোনো চিকিৎসা পরামর্শ, রোগ নির্ণয়, বা চিকিৎসা সেবার বিকল্প নয়। ওষুধ শুরু, বন্ধ, বা পরিবর্তনের যেকোনো সিদ্ধান্তের আগে অবশ্যই একজন যোগ্য ডাক্তারের পরামর্শ নিন। রিমাইন্ডার নোটিফিকেশন ফোনের সিস্টেম সেটিংস, ব্যাটারি অপ্টিমাইজেশন, বা নেটওয়ার্ক সমস্যার কারণে বিলম্বিত বা বাদ যেতে পারে — তাই এটিকে একমাত্র নির্ভরযোগ্য মাধ্যম হিসেবে বিবেচনা না করাই ভালো।"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
