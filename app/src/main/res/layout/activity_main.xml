<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Gradient Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_header"
                android:padding="24dp">

                <TextView
                    android:id="@+id/greetingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/greeting_morning"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/home_subtitle"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp" />

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/totalCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/today_medicines"
                            android:textColor="#D9FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/takenCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/taken_label"
                            android:textColor="#D9FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/missedCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/missed_label"
                            android:textColor="#D9FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                android:rowCount="5"
                android:useDefaultMargins="false">

                <TextView
                    android:id="@+id/statsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/stats_button"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/calendarButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/calendar_button"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/lowStockButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/low_stock_button"
                    android:textColor="@color/danger"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/searchButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/search_button"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/darkModeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/theme_button"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/backupButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/backup_button"
                    android:textColor="@color/success"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/healthButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/health_button"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/ocrButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/ocr_button"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/voiceReminderButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/voice_reminder_off"
                    android:textColor="@color/warning"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />
                <TextView
                    android:id="@+id/languageButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:minHeight="90dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/language_button"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="3" />

            </GridLayout>

            <!-- Next Dose Card -->
            <LinearLayout
                android:id="@+id/nextDoseCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_margin="16dp"
                android:padding="18dp"
                android:elevation="3dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="পরবর্তী ওষুধ"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nextDoseName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Medicine Name"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nextDoseCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="00:00:00"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="তোমার ওষুধ তালিকা"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/emptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="এখনো কোনো ওষুধ যোগ করা হয়নি।\n+ বাটনে চাপ দিয়ে শুরু করো।"
                android:textAlignment="center"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:padding="40dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/medicineRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/addFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="ওষুধ যোগ করো"
        android:textColor="@color/white"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/white"
        app:backgroundTint="@color/secondary"
        app:cornerRadius="20dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
