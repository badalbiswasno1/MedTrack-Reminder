<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="প্রেসক্রিপশন স্ক্যান করুন"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ছবি তুলুন বা বেছে নিন, তারপর ওষুধের নাম বেছে নিন"
                android:textColor="#D9FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/cameraButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_day_upcoming"
                android:gravity="center"
                android:padding="14dp"
                android:text="ক্যামেরা"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/galleryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:padding="14dp"
                android:text="গ্যালারি"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

        <ImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginHorizontal="16dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_card"
            android:visibility="gone" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="প্রথমে একটি ছবি বেছে নিন"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="সনাক্ত হওয়া লাইনগুলো (ট্যাপ করে বেছে নিন):"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/detectedLinesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </LinearLayout>
</ScrollView>
