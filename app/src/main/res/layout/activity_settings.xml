<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="সেটিংস"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_margin="16dp"
            android:padding="4dp">

            <LinearLayout
                android:id="@+id/darkModeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎨 থিম"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/darkModeValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="সিস্টেম অনুযায়ী"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/outline" />

            <LinearLayout
                android:id="@+id/voiceReminderRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔊 ভয়েস রিমাইন্ডার"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/voiceReminderValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="বন্ধ"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/outline" />

            <LinearLayout
                android:id="@+id/languageRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌐 ভাষা"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/languageValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="বাংলা"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/outline" />

            <LinearLayout
                android:id="@+id/backupRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💾 ব্যাকআপ ও এক্সপোর্ট"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="18sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
